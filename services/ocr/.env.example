# OCR analysis mode: vl (PaddleOCR-VL, recommended) or ppocr (PP-OCR fallback)
OCR_ANALYSIS_MODE=vl

# Compute device for PaddleOCR: cpu or gpu
PADDLEOCR_DEVICE=cpu

# VL recognition backend (optional, defaults to paddleocr built-in)
# PADDLEOCR_VL_REC_BACKEND=

# VL recognition server URL (required if using a remote VL backend)
# PADDLEOCR_VL_REC_SERVER_URL=http://localhost:8800

# Disable PaddleOCR model source check (set to 1 in offline / air-gapped environments)
# PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=1
